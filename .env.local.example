# Copy to .env.local and fill in your values

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (required for password reset emails — use your live Vercel URL in production)
NEXT_PUBLIC_APP_URL=https://staff-attendance-system-tau.vercel.app

# Database migrations only (optional — from Supabase Dashboard → Database → password)
# SUPABASE_DB_PASSWORD=your-database-password

# Desktop app port (optional)
# ATTENDPRO_PORT=3847
